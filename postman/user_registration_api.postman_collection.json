  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /heartbeat",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/heartbeat",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "heartbeat"
              ]
            },
            "description": "Liveness endpoint."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('body has ok status', function () {",
                  "  var data = pm.response.json();",
                  "  pm.expect(data.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/plain"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "metrics"
              ]
            },
            "description": "Prometheus scrape endpoint for in-process dispatch and operational metrics."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('content-type is prometheus text format', function () {",
                  "  var contentType = pm.response.headers.get('Content-Type') || '';",
                  "  pm.expect(contentType).to.include('text/plain');",
                  "  pm.expect(contentType).to.include('version=');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "POST /v1/users (register)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "users"
              ]
            },
            "description": "Creates a pending account and schedules activation email."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('response has pending status', function () {",
                  "  var data = pm.response.json();",
                  "  pm.expect(data.email).to.eql(pm.collectionVariables.get('email'));",
                  "  pm.expect(data.status).to.eql('PENDING');",
                  "  pm.collectionVariables.set('userId', String(data.id));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /v1/users/activate",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{email}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
